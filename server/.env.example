# ---------------------------------------------------------------------------
# Team Fintness CRM — backend environment configuration
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
# ---------------------------------------------------------------------------

# PostgreSQL connection strings. TWO are needed on Supabase (both change
# together if you move hosts later):
#
#  - DATABASE_URL: the POOLED connection the running app uses for everyday
#    queries (many short-lived connections is normal app behavior).
#    Supabase: Project Settings -> Database -> Connection string -> URI ->
#    "Transaction" mode, port 6543. Append ?pgbouncer=true. Example:
#    postgresql://postgres:<PASSWORD>@aws-1-<region>.pooler.supabase.co:6543/postgres?pgbouncer=true
#
#  - DIRECT_URL: an UNPOOLED, direct connection used only by
#    `prisma migrate deploy`/`generate` at build/deploy time. Supabase:
#    same page -> "Direct connection", port 5432. Example:
#    postgresql://postgres:<PASSWORD>@db.<ref>.supabase.co:5432/postgres
#
#    Do NOT point DATABASE_URL at the "Session" mode pooler (also port
#    5432, different host) — that pooler caps out at 15 total clients, and
#    the running app alone can hold most/all of them, so a deploy's
#    migration step can no longer get a connection ("max clients reached in
#    session mode") and the whole build fails. Session mode isn't used here.
#
#  - Local / Mac Mini Postgres (no pooler — both vars are the same URL):
#    postgresql://postgres:postgres@localhost:5432/fintness_crm
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/fintness_crm"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/fintness_crm"

# Secret used to sign session JWTs. Generate a long random value, e.g.:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET="change-me-to-a-long-random-secret"

# How long a login session lasts.
TOKEN_TTL="7d"

# The frontend origin allowed to call this API (Vite dev server by default).
# In production set this to your deployed frontend URL.
CLIENT_ORIGIN="http://localhost:5173"

# API server port.
PORT=4000

# "development" or "production". In production the session cookie is marked
# Secure (HTTPS-only).
NODE_ENV="development"

# bcrypt cost factor for password hashing (10-12 is a good range).
BCRYPT_ROUNDS=12

# ---- Initial admin (used only by `npm run seed`) --------------------------
# The first admin account. Change the password immediately after first login.
SEED_ADMIN_NAME="Nitesh Luthra"
SEED_ADMIN_EMAIL="mail@fintness.in"
SEED_ADMIN_PASSWORD="ChangeMe#2026"

# ---- Web Push (OS-level notifications) -------------------------------------
# Generate a keypair with `npx web-push generate-vapid-keys` (run from
# server/). Optional: leave blank to disable Web Push — the in-app bell and
# live socket notifications keep working regardless. The PUBLIC key is not a
# secret and must also be set as VITE_VAPID_PUBLIC_KEY in the frontend's
# .env.local / hosting env vars (same value, both sides of one keypair).
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:mail@fintness.in"

# ---- Portfolio Review (AI PDF analysis) ------------------------------------
# Gemini API key used server-side to analyze uploaded portfolio statement
# PDFs. Never sent to the browser — the client only calls our own API.
GEMINI_API_KEY=""
