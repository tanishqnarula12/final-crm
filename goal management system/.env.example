# Copy to .env.local for local dev. Never commit .env.local (already gitignored via *.local).

# Backend API base URL (the Express server in server/).
VITE_API_URL=http://localhost:4000/api

# Optional — Gemini API key, if AI features are wired up to call it directly
# from the browser. NOTE: anything prefixed VITE_ is bundled into the public
# JS and visible to anyone; a key that must stay secret belongs behind a
# server/ route instead, not here.
VITE_GEMINI_API_KEY=

# Web Push public key — the PUBLIC half of the VAPID keypair generated on the
# server (server/.env's VAPID_PUBLIC_KEY). Not a secret. Leave blank to
# disable the "OS notification" install/subscribe flow (in-app bell still works).
VITE_VAPID_PUBLIC_KEY=
